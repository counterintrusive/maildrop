# Flask server config
FLASK_HOST = "0.0.0.0"
FLASK_PORT = 5000

# SMTP server config
SMTP_HOST = "0.0.0.0"
SMTP_PORT = 25

# File config
INBOX_FILE_NAME = "inbox.json" # this is the file where emails are stored.
MAX_INBOX_SIZE = 100000000 # 100MB (in bytes) (clears inbox when reached)

# Email config
PROTECTED_ADDRESSES = "^admin.*" # regex for inboxes that need a password

# Password
PASSWORD = "password" # admin password needed to access protected emails, change settings (not implemented), etc.

# Domain config
DOMAINS = "yourdomain.com" # comma-separated list of domains to accept mail for

# -- Rate limiting (C1) --
SMTP_RATE_LIMIT = 10       # max connections per IP within the window
SMTP_RATE_WINDOW = 60      # window in seconds
SMTP_MAX_MSGS_PER_CONN = 20  # max messages per connection

# -- Email size limit (C2) --
MAX_EMAIL_SIZE = 10000000  # 10 MB max per email

# -- Per-inbox storage (C3) --
INBOX_DIR = "inboxes"      # directory for per-inbox JSON files
MAX_EMAILS_PER_INBOX = 500 # max emails per inbox before oldest eviction

# -- Privilege drop (H4) --
DROP_PRIV_USER = ""        # user to drop to after binding SMTP port (empty = stay as root).
                           # setuid() affects ALL threads, so the install directory must be
                           # readable by this user. Only set if you understand the implications.

# -- SMTP TLS (M1) --
SMTP_TLS_CERT = ""         # path to TLS certificate file (leave empty to disable STARTTLS)
SMTP_TLS_KEY = ""          # path to TLS private key file

# -- CSRF / Origin validation (H3) --
ALLOWED_ORIGINS = ""       # comma-separated origins allowed for POST /send_email (e.g. "https://maildrop.example.com")

# -- Flask secret key (L3) --
FLASK_SECRET_KEY = ""      # used for session signing. Generate: python -c "import secrets; print(secrets.token_hex(32))"

# -- FOR SENDING EMAILS (ignore if you only want to receive) --

ENABLE_SENDING = false # set to true to enable sending emails

# SMTP Relay
RELAY_HOST = "" # host of smtp relay to send emails through
RELAY_PORT = 2525 # the port of the smtp relay
RELAY_USER = "" # the username to log in with (optional)
RELAY_PASS = "" # the password to log in with (optional)
